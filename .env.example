# Local development
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://digital_meetup:change-me@localhost:5432/digital_meetup
DJANGO_SETTINGS_MODULE=config.settings.local

# Production (Render) — set these in the Render dashboard
# DEBUG=False
# DJANGO_SETTINGS_MODULE=config.settings.production
# ALLOWED_HOSTS=your-app.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# DATABASE_URL=<from Render PostgreSQL>
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=<choose-a-strong-password>
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# Note: on Render free tier, uploaded images are stored on ephemeral disk
# and may be lost on redeploy. Use a paid plan + persistent disk for production media.
